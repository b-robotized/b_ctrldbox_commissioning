<ROOT>
  <CONFIG>
    <IP_NUMBER>10.23.23.28</IP_NUMBER>  <!-- IP-number of the external socket -->
      <PORT>28283</PORT>                <!-- Port-number of the external socket -->
      <SENTYPE>KROSHU</SENTYPE>         <!-- The name of your system send in <Sen Type="" > -->
      <ONLYSEND>FALSE</ONLYSEND>        <!-- TRUE means the client don't expect answers. Do not send anything to robot -->
  </CONFIG>
  <SEND>
    <ELEMENTS>
      <ELEMENT TAG="DEF_RIst"  TYPE="DOUBLE" INDX="INTERNAL" />  <!-- Cartesian position -->
      <ELEMENT TAG="DEF_AIPos" TYPE="DOUBLE" INDX="INTERNAL" />  <!-- Joint position -->
      <ELEMENT TAG="DEF_EIPos" TYPE="DOUBLE" INDX="INTERNAL" />  <!-- External axis position -->
      <ELEMENT TAG="DEF_Delay" TYPE="LONG" INDX="INTERNAL" />    <!-- Number of late packets -->
    </ELEMENTS>
  </SEND>
  <RECEIVE>
    <ELEMENTS>
      <!-- Stop flag -->
      <ELEMENT TAG="Stop"  TYPE="BOOL" INDX="1" HOLDON="0" />
      <!-- Joint setpoints -->
      <ELEMENT TAG="AK.A1" TYPE="DOUBLE" INDX="2" HOLDON="1" />
      <ELEMENT TAG="AK.A2" TYPE="DOUBLE" INDX="3" HOLDON="1" />
      <ELEMENT TAG="AK.A3" TYPE="DOUBLE" INDX="4" HOLDON="1" />
      <ELEMENT TAG="AK.A4" TYPE="DOUBLE" INDX="5" HOLDON="1" />
      <ELEMENT TAG="AK.A5" TYPE="DOUBLE" INDX="6" HOLDON="1" />
      <ELEMENT TAG="AK.A6" TYPE="DOUBLE" INDX="7" HOLDON="1" />
    </ELEMENTS>
  </RECEIVE>
</ROOT>
