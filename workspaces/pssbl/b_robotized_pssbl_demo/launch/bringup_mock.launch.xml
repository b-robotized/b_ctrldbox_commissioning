<launch>
  <arg name="robot_model" default="2257" description="Robot model: 1215 or 2257">
    <choice value="1215"/>
    <choice value="2257"/>
  </arg>

  <arg name="description_package"
       default="pssbl_robot_descriptions"
       description="Description package with robot URDF/xacro files."/>

  <arg name="configuration_package"
       default="b_robotized_pssbl_demo"
       description="The ROS package where we find the configuration files."/>

  <!-- Load robot description with mock hardware -->
  <include file="$(find-pkg-share $(var description_package))/launch/description.launch.xml">
    <arg name="robot_model" value="$(var robot_model)"/>
    <arg name="hardware" value="mock"/>
  </include>

  <let name="controllers_file_path"
       value="$(find-pkg-share $(var configuration_package))/config/scenario_controllers.yaml"/>

  <!-- Controller manager -->
  <node pkg="controller_manager" exec="ros2_control_node" name="b_controlled_box_cm" output="both">
    <param from="$(var controllers_file_path)"/>
  </node>

  <!-- Spawn and activate core controllers -->
  <node pkg="controller_manager" exec="spawner" name="joint_state_broadcaster_spawner" output="screen"
        args="joint_state_broadcaster -c /b_controlled_box_cm"/>
  <node pkg="controller_manager" exec="spawner" name="joint_trajectory_controller_spawner" output="screen"
        args="joint_trajectory_controller -c /b_controlled_box_cm"/>

</launch>
