<launch>

  <arg name="controller_manager_name" default="/b_controlled_box_cm"/>

  <!-- Spawn all controllers as inactive (to be activated later via scripts or service calls) -->
  <node pkg="controller_manager" exec="spawner"
        args="joint_state_broadcaster -c $(var controller_manager_name) --inactive"/>
  <node pkg="controller_manager" exec="spawner"
        args="joint_trajectory_controller -c $(var controller_manager_name) --inactive"/>
  <node pkg="controller_manager" exec="spawner"
        args="tool_controller -c $(var controller_manager_name) --inactive"/>

</launch>
