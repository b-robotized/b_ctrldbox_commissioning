<launch>
  <arg name="robot_model" default="2257" description="Robot model: 1215 or 2257">
    <choice value="1215"/>
    <choice value="2257"/>
  </arg>

  <arg name="description_package"
       default="pssbl_robot_descriptions"
       description="Description package with robot URDF/xacro files."/>

  <arg name="prefix"
       default=""
       description="Prefix of the joint names, useful for multi-robot setup."/>

  <!-- Load robot description with mock hardware -->
  <include file="$(find-pkg-share $(var description_package))/launch/description.launch.xml">
    <arg name="robot_model" value="$(var robot_model)"/>
    <arg name="prefix" value="$(var prefix)"/>
    <arg name="hardware" value="mock"/>
  </include>

  <!-- Joint state publisher GUI for interactive joint control -->
  <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui"/>

  <!-- RViz -->
  <node pkg="rviz2" exec="rviz2" name="rviz2" output="both"
        args="-d $(find-pkg-share $(var description_package))/config/view.rviz"/>

</launch>
